<Window x:Class="SafeExamBrowser.UserInterface.Desktop.Windows.MonitoringConsole"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Monitoring Console" Height="600" Width="1000" WindowStyle="ToolWindow" Background="#F0F0F0">
    <Grid>
        <TabControl>
            <TabItem Header="Traffic Monitoring">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="TrafficGrid" AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding TrafficLog}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="80" />
                            <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="60" />
                            <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*" />
                            <DataGridCheckBoxColumn Header="Blocked" Binding="{Binding Blocked}" Width="60" />
                            <DataGridTemplateColumn Header="Action" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Toggle Block" Click="BlockButton_Click" Tag="{Binding Url}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                        <Button Content="Clear Log" Click="ClearButton_Click" Padding="10,2" Margin="5" />
                        <TextBlock Text="Blocked Domains: " VerticalAlignment="Center" Margin="10,0,5,0" />
                        <ItemsControl ItemsSource="{Binding BlockedDomains}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Search Browser">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Margin="5" KeyDown="SearchBox_KeyDown" />
                        <Button Grid.Column="1" Content="Go" Click="GoButton_Click" Width="50" Margin="5" />
                    </Grid>
                    <WindowsFormsHost Grid.Row="1" x:Name="SearchBrowserHost" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
